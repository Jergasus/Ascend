// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- APP MODELS ---

enum Frequency {
  DAILY
  EVERY_TWO_DAYS
  WEEKENDS
  CUSTOM
}

model Habit {
  id         Int       @id @default(autoincrement())
  name       String
  color      String    @default("#ffffff")
  category   String    @default("General")
  order      Int       @default(0)
  frequency  Frequency @default(DAILY)
  customDays String? // Format: "1,3,5" for Monday, Wednesday, Friday (0=Sunday, 6=Saturday)
  notificationTime String? // Notification time (e.g.: "08:00")
  dailyGoal  Int       @default(1) // Number of times to complete per day
  createdAt  DateTime  @default(now()) // Creation date used to calculate "every 2 days"
  completions Completion[]

  // Each Habit belongs to ONE User
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name]) // Prevents a user from having duplicate habits
}

model Completion {
  id   Int      @id @default(autoincrement())
  date DateTime
  value Int     @default(1) // Current progress value (e.g.: 1, 2, 3...)

  // The completion belongs to ONE Habit
  habitId Int
  habit   Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  // Prevents marking the same habit twice on the same day
  @@unique([habitId, date])
}

// --- MODELS REQUIRED BY NEXT-AUTH ---
// (You don't need to understand these, just copy them)

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  themeColor      String?   @default("#ffffff")
  dashboardColors Json? // Custom dashboard colors
  hasSeenTutorial Boolean   @default(false)
  // NextAuth connections
  accounts        Account[]
  sessions        Session[]

  // A User can have MANY Habits
  habits Habit[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
